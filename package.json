{
  "name": "express-template",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "start": "node .",
    "dev": "concurrently \"yarn watch:css\" \"nodemon .\"",
    "build:css": "tailwindcss -i ./input.css -o ./public/css/style.css",
    "watch:css": "tailwindcss -i ./input.css -o ./public/css/style.css --watch"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1"
  }
}
